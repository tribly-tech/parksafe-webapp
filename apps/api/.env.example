# Database (required when OTP_DEV_MODE=false)
DATABASE_URL=postgresql://user:password@localhost:5432/parksafe

# Integration tests use a separate DB (parksafe_test) — never wipes parksafe
# DATABASE_URL_TEST=postgresql://user:password@localhost:5432/parksafe_test

# JWT (required when OTP_DEV_MODE=false)
JWT_ACCESS_SECRET=generate-with-openssl-rand-base64-32
JWT_REFRESH_SECRET=generate-with-openssl-rand-base64-32
PII_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# OTP + sessions
OTP_HMAC_SECRET=generate-with-openssl-rand-base64-32
SESSION_SIGNING_SECRET=generate-with-openssl-rand-base64-32

# Redis (optional — omit to use in-memory OTP store; recommended for production)
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-token

# WhatsApp — AiSensy (default provider)
WHATSAPP_PROVIDER=aisensy
AISENSY_API_KEY=your-aisensy-api-key
# AISENSY_API_URL=https://backend.aisensy.com/campaign/t1/api/v2

# Live API campaign names — must match AiSensy dashboard exactly
AISENSY_CAMPAIGN_OTP=ParkSafe_OTP
AISENSY_CAMPAIGN_BLOCKING_VEHICLE=ParkSafe_Blocking
AISENSY_CAMPAIGN_WRONG_PARKING=ParkSafe_WrongParking
AISENSY_CAMPAIGN_LIGHTS_ON=ParkSafe_LightsOn
AISENSY_CAMPAIGN_DOOR_OPEN=ParkSafe_DoorOpen
AISENSY_CAMPAIGN_FLAT_TYRE=ParkSafe_FlatTyre
AISENSY_CAMPAIGN_FLUID_LEAKING=ParkSafe_FluidLeaking
AISENSY_CAMPAIGN_VEHICLE_DAMAGE=ParkSafe_VehicleDamage
AISENSY_CAMPAIGN_EMERGENCY=ParkSafe_Emergency

# WhatsApp — Meta direct (only when WHATSAPP_PROVIDER=meta)
# WHATSAPP_ACCESS_TOKEN=your-meta-access-token
# WHATSAPP_PHONE_ID=your-phone-number-id

# Exotel (call relay)
EXOTEL_SID=your-exotel-sid
EXOTEL_TOKEN=your-exotel-token
EXOTEL_CALLER_ID=+919999999999

# App
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:3000
PORT=3001

# Local dev: OTP logged to terminal, dev-store used. Set false for production path.
OTP_DEV_MODE=true

# Admin QR tag generation (min 32 chars)
ADMIN_API_KEY=dev-only-admin-api-key-32chars-minimum
SITE_URL=http://localhost:3000

# Without DATABASE_URL: admin uses in-memory mock (3 batches, 225 tags) on API boot.
# With DATABASE_URL: admin mock is seeded into Postgres automatically in development.
