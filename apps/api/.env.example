# ── Supabase ────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Twilio ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_RELAY_NUMBER=+91XXXXXXXXXX

# ── WhatsApp Business API ────────────────────────────────
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_ID=your-phone-number-id

# ── Exotel (call relay) ──────────────────────────────────
EXOTEL_SID=your-exotel-sid
EXOTEL_TOKEN=your-exotel-token
EXOTEL_CALLER_ID=+91XXXXXXXXXX

# ── MSG91 (SMS fallback) ─────────────────────────────────
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=PRKSFE

# ── Upstash Redis ────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ── Secrets (min 32 chars each) ──────────────────────────
OTP_HMAC_SECRET=generate-with-openssl-rand-base64-32
SESSION_SIGNING_SECRET=generate-with-openssl-rand-base64-32

# ── App ──────────────────────────────────────────────────
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:3000
PORT=3001

# Local dev: OTP is logged to the API terminal (no SMS). Set to false when testing real SMS.
OTP_DEV_MODE=true
