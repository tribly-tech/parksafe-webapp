# API — sole backend connection (browser uses /backend proxy)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Analytics (optional — enabled in production when key is set)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Set to true to capture events in local/staging dev
NEXT_PUBLIC_POSTHOG_ENABLED=false
# Set to true to disable analytics even when a key is present
NEXT_PUBLIC_POSTHOG_DISABLED=false

# Error tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=

# Dev: auto-login to seeded dashboard user
NEXT_PUBLIC_DEV_SKIP_AUTH=true
